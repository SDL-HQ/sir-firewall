{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdl.internal/sir/spec/scenarios/scenario_schema.v1.json",
  "title": "SIR Scenario Pack Schema v1",
  "type": "object",
  "required": ["scenario_id", "version", "turns"],
  "properties": {
    "scenario_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["turn_id", "expected"],
        "properties": {
          "turn_id": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "enum": ["user", "system", "assistant"], "default": "user" },
          "content": { "type": "string", "minLength": 1 },
          "content_b64": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "enum": ["allow", "block"] },
          "note": { "type": "string" },
          "category": { "type": "string" }
        },
        "oneOf": [
          { "required": ["content"], "not": { "required": ["content_b64"] } },
          { "required": ["content_b64"], "not": { "required": ["content"] } }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
